---
import { Image } from "astro:assets";
import avatar from "../assets/avatar.jpg";

const url = new URL(Astro.url);
const avatarParameter = url.searchParams.get("avatar");
---

<div class="max-w-3xl mx-auto my-10 bg-white p-8 rounded-lg">
  <div class="grid grid-cols-8 gap-4">
    <div class="col-span-6">
      <section>
        <div class="text-2xl font-semibold">
          Stanislav Strugovshchikov (Stas)
        </div>
        <div>Full-Stack Developer</div>
        <div>Orlando, Florida, 🇺🇸 United States</div>
      </section>

      <section class="mt-4">
        <h2 class="text-xl font-semibold">Contact</h2>
        <p>📞 +1 (786) 325 4891</p>
        <p>✉️ stanislav.stru@gmail.com</p>
        <div class="flex gap-3 divide-x divide-gray-500 mt-4">
          <span class="pr-3">
            🔗 <a
              href="https://www.linkedin.com/in/strugovshchikov"
              class="text-blue-600">LinkedIn</a
            >
          </span>
          <span>
            🔗 <a href="https://github.com/stanislavstru" class="text-blue-600"
              >GitHub</a
            >
          </span>
        </div>
      </section>
    </div>
    {
      avatarParameter && (
        <div class="col-span-2">
          <Image
            src={avatar}
            alt="Stanislav Strugovshchikov"
            class="rounded-lg"
          />
        </div>
      )
    }
  </div>

  <section class="mt-6">
    <h2 class="text-xl font-semibold">Summary</h2>
    <p class="ml-3 mt-1">
      Full-Stack Developer with over 6 years of experience in web application
      development, AI assistant integration, and scalable front-end and back-end
      solutions. Expert in JavaScript, Node.js, React, Next.js, PHP, and
      microfrontend architectures. Extensive experience in building social
      networks and complex platforms from scratch.
    </p>
  </section>

  <section class="mt-6">
    <h2 class="text-xl font-semibold">Skills</h2>
    <ul class="list-disc ml-6 mt-1">
      <li>
        <strong>Frontend:</strong> React, Next.js, TypeScript, Redux, TailwindCSS
      </li>
      <li>
        <strong>Backend:</strong> Node.js, Express, NestJS, PHP (Yii2, Laravel)
      </li>
      <li><strong>Databases:</strong> PostgreSQL, MongoDB, MySQL</li>
      <li><strong>DevOps & Tools:</strong> Docker, AWS, Firebase, Vercel</li>
      <li>
        <strong>AI & Integrations:</strong> OpenAI API, ChatGPT, Stripe API
      </li>
      <li>
        <strong>Other:</strong> Microservices, GraphQL, REST API, WebSockets
      </li>
    </ul>
  </section>

  <section class="mt-6">
    <h2 class="text-xl font-semibold">Experience</h2>

    <div class="ml-3 mt-1">
      <div class="mt-2">
        <h3 class="text-md font-bold">Criya | Software Engineer</h3>
        <p class="text-gray-600">
          June 2022 - Present (2 years 9 months) | United States
        </p>
        <ul class="list-disc ml-6">
          <li>Integrated AI assistants to automate user workflows.</li>
          <li>Optimized JavaScript data streaming, reducing latency by 30%.</li>
          <li>Enhanced chat flow UX for real-time interactions.</li>
        </ul>
      </div>

      <div class="mt-3">
        <h3 class="text-md font-bold">DZ Systems | Software Engineer</h3>
        <p class="text-gray-600">
          February 2021 - June 2022 (1 year 5 months) | Russia
        </p>
        <ul class="list-disc ml-6">
          <li>Developed a social network for business professionals.</li>
          <li>Built microservices architecture for high scalability.</li>
          <li>Implemented a WebSockets-powered chat system.</li>
        </ul>
      </div>

      <div class="mt-3">
        <h3 class="text-md font-bold">Seldon Pro | Software Engineer</h3>
        <p class="text-gray-600">
          May 2020 - December 2021 (1 year 8 months) | Russia
        </p>
        <ul class="list-disc ml-6">
          <li>Contributed to a B2B market analytics platform.</li>
          <li>Optimized PostgreSQL database performance by 25%.</li>
        </ul>
      </div>

      <div class="mt-3">
        <h3 class="text-md font-bold">Mebelidomanet | Full-Stack Developer</h3>
        <p class="text-gray-600">
          April 2017 - May 2020 (3 years 2 months) | Russia
        </p>
        <ul class="list-disc ml-6">
          <li>Developed the core of an e-commerce store using Yii2.</li>
          <li>Created an admin dashboard with React.</li>
        </ul>
      </div>
    </div>
  </section>

  <section class="mt-6">
    <h2 class="text-xl font-semibold">Soft Skills</h2>
    <ul class="list-disc ml-6 mt-1">
      <li>
        <strong>Team Collaboration:</strong> Effective communicator and team player
        with experience working in multicultural and cross-functional teams.
      </li>
      <li>
        <strong>Problem Solving:</strong> Adept at analyzing complex technical challenges
        and implementing innovative solutions.
      </li>
      <li>
        <strong>Adaptability:</strong> Quick to learn new technologies and adjust
        to rapidly changing project requirements.
      </li>
      <li>
        <strong>Leadership:</strong> Proven ability to lead projects and mentor junior
        developers in both domestic and international settings.
      </li>
    </ul>
  </section>

  <section class="mt-6">
    <h2 class="text-xl font-semibold">Education</h2>
    <p class="ml-3 mt-1">
      <strong>Russia, Nizhniy Novgorod, State Technical University</strong> (2012
      - 2017)
    </p>
  </section>

  <section class="mt-6 text-center">
    <p>🚀 Open to new opportunities and collaborations!</p>
  </section>
</div>
